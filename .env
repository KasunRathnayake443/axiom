# ========== SMTP CONFIGURATION ==========
# Laragon Mailpit defaults — change these for production

MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=false

# Where form submissions get sent
MAIL_TO=owner@axiomglobal.com
MAIL_FROM=noreply@axiomglobal.com
MAIL_FROM_NAME=Axiom Global Website